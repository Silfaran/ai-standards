{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(pwd)",
      "Bash(docker *)",
      "Bash(php *)",
      "Bash(npm *)",
      "Bash(cd *)",
      "Bash(composer *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '(.tool_input.model // \"\") != \"\"' >/dev/null || printf \"%s\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Agent() invocation is missing the model parameter. Read the ## Model line from the agent definition file (ai-standards/agents/*.md) and pass opus or sonnet as the model argument.\"}}'"
          },
          {
            "type": "command",
            "command": "bash ai-standards/tests/harness/hooks/capture-agent-full.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ai-standards/tests/harness/hooks/snapshot-handoff.sh"
          }
        ]
      }
    ]
  }
}
